{
  "name": "logslice",
  "version": "0.1.0",
  "description": "A streaming command-line log explorer for large log files.",
  "type": "module",
  "bin": {
    "logslice": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
